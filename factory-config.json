{
  "fabrica": {
    "version": "2.1",
    "rutas_core_assets": {
      "frontend": "./frontend",
      "backend": "./backend"
    },
    "repositorio_librerias": "github:alexlunamayo2002-netizen/fabrica-software-academico",
    "ramas_librerias": {
      "@fabrica/node-core": "pkg/node-core",
      "@fabrica/academico": "pkg/academico"
    }
  },
  "configuracion_nuevo_proyecto": {
    "nombre_default": "NuevoProyectoApp",
    "_ayuda": "Solo edita el bloque 'opcionales'. Los 'obligatorios' son commonalities: el sistema los fuerza a true aunque los pongas en false.",
    "core_assets": {
      "obligatorios": {
        "CA-001_DesignSystem": true,
        "CA-002_ModeloUsuarioFront": true,
        "CA-003_AuthService": true,
        "CA-004_AuthGuard": true,
        "CA-005_RoleGuard": true,
        "CA-006_Login": true,
        "CA-008_Dashboard": true,
        "CA-009_EsquemaGraphQLBase": true,
        "CA-010_ResolversGraphQL": true,
        "CA-011_JWTMiddleware": true,
        "CA-013_ConfiguracionBD": true
      },
      "opcionales": {
        "CA-007_RegistroAbierto": true,
        "CA-012_ModeloAuditoria": true,
        "CA-016_ModuloMaterias": true,
        "CA-017_ModuloInscripciones": true,
        "CA-018_SetupBD_Automatico": true
      }
    },
    "entorno": {
      "db_host_template": "tu-host.render.com",
      "puerto_backend": 4000,
      "db_local": {
        "host": "localhost",
        "port": 5544,
        "user": "root",
        "password": "secret",
        "ssl": false
      }
    }
  }
}
